# HELIOS secrets — never commit real values
HELIOS_DATA_DIR=./data
HELIOS_CONFIG=helios.config.yaml
HELIOS_DRY_RUN=0
HELIOS_HTTP_PORT=8791
# HELIOS_API_KEY=           # for POST /v1/jobs (v1.1)

# YouTube OAuth
YOUTUBE_CLIENT_SECRET=/path/to/client_secret.json
YOUTUBE_TOKEN=/path/to/youtube_token.json

# Director LLM (default: DeepSeek)
HELIOS_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=

# CALLIOPE screenwriter — shares MNEMOSYNE with DIOSCURI
# DIOSCURI_DATA_DIR=/data
# HELIOS_MNEMOSYNE_PATH=/data/mnemosyne.json
# HELIOS_LLM_FALLBACK_PROVIDER=ollama
# HELIOS_LLM_FALLBACK_BASE_URL=http://localhost:11434/v1
# HELIOS_LLM_FALLBACK_MODEL=llama3.1

# Optional: openai-compatible / anthropic / ollama / lmstudio / llamacpp
# HELIOS_LLM_PROVIDER=openai-compatible
# HELIOS_LLM_BASE_URL=http://127.0.0.1:1234/v1
# HELIOS_LLM_API_KEY=

HELIOS_WEBHOOK_URL=
